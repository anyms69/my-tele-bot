# ════════════════════════════════════════════════
#  Antalya Mini App — переменные окружения
# ════════════════════════════════════════════════

# ── Google Sheets ────────────────────────────────
# 1. Создай таблицу, вставь код из src/data/appsscript-template.js
# 2. Расширения → Apps Script → Развернуть → Веб-приложение
# 3. Доступ: Все → Скопируй URL сюда:
VITE_SHEETS_URL=https://script.google.com/macros/s/YOUR_ID/exec

# ── Telegram Bot ─────────────────────────────────
# 1. Напиши @BotFather → /newbot → получи токен
# 2. Чтобы узнать свой chat_id: напиши боту любое сообщение,
#    потом открой: https://api.telegram.org/bot<TOKEN>/getUpdates
#    → найди "chat":{"id":XXXXXXXXX}
VITE_BOT_TOKEN=123456789:ABCdefGHI-jklMNOpqrSTUvwxYZ
VITE_OWNER_CHAT_ID=123456789

# ── Telegram Payments ────────────────────────────
# 1. @BotFather → /mybots → выбери бота → Payments
# 2. Подключи Stripe (TEST для разработки)
# 3. Скопируй токен провайдера сюда:
VITE_PAYMENT_PROVIDER_TOKEN=284685063:TEST:NjQ0NjU4...
